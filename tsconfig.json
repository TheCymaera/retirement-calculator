{
	"exclude": [
		"node_modules",
		"dist",
		"src/service-worker.ts",
	],
	"compilerOptions": {
		"target": "ESNext",

		"module": "NodeNext",
		"moduleResolution": "NodeNext",

		"strict": true,
		"noImplicitReturns": true,
		"noUncheckedIndexedAccess": true,

		"noEmit": true,
		"skipLibCheck": true,

		"types": [
			"@types/bun",
		],
	}
}